<Window x:Class="WaferUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WaferUI"
        mc:Ignorable="d"
        Title="Wafer AOI 검사" Height="560" Width="920"
        MinHeight="500" MinWidth="780">
    <Grid Background="#F5F7FA" Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#D7DDE5" BorderThickness="1" CornerRadius="6" Padding="14">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="TestImages"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           Margin="0,0,0,12"/>
                <Button DockPanel.Dock="Bottom"
                        Content="폴더 새로고침"
                        Height="34"
                        Margin="0,12,0,0"
                        Click="RefreshImagesButton_Click"/>
                <ListBox x:Name="ImageListBox"
                         DisplayMemberPath="FileName"
                         SelectionChanged="ImageListBox_SelectionChanged"
                         BorderBrush="#D7DDE5"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Background="White" BorderBrush="#D7DDE5" BorderThickness="1" CornerRadius="6" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#111827" CornerRadius="4">
                    <Image x:Name="WaferImage"
                           Stretch="Uniform"
                           Margin="14"/>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="SelectedImageText"
                                   Text="이미지를 선택하세요"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"/>
                        <TextBlock x:Name="InferenceResultText"
                                   Text="분석 대기 중"
                                   FontSize="15"
                                   Foreground="#475569"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="AnalyzeButton"
                            Content="분석 실행"
                            Height="42"
                            VerticalAlignment="Center"
                            Click="AnalyzeButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
